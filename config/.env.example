# ============================================================
# 环境变量配置模板
# 使用说明: 复制此文件为 .env，填写真实密钥后使用
# 警告: .env 文件严禁提交到 Git 仓库！
# ============================================================

# -------------------- 阿里云 OSS 配置 --------------------
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
OSS_BUCKET_NAME=your_bucket_name

# -------------------- ClickHouse 配置 --------------------
CK_HOST=localhost
CK_PORT=9000
CK_USER=default
CK_PASSWORD=your_password_here
CK_DATABASE=ecommerce

# -------------------- 数据生成配置 --------------------
DATA_TOTAL_SIZE_MB=100
DATA_OUTPUT_DIR=data/raw
